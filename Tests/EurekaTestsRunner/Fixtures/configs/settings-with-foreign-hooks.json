{
  "model": "claude-fable-5",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "/usr/local/bin/terminal-notifier -message done" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "/Users/me/bin/audit.sh" }
        ]
      }
    ]
  }
}
